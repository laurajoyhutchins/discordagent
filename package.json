{
  "name": "discord-agent",
  "version": "1.0.0",
  "description": "Provider-neutral Discord workspace: run Claude, Codex, and OpenCode coding agents from private Discord with isolated Git worktrees",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "register": "tsx src/commands/register.ts",
    "discord:permissions": "tsx src/discord/capabilities/calculator.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --coverage",
    "lint": "node scripts/check-source-policy.mjs",
    "format:check": "node scripts/check-format.mjs",
    "check": "npm run typecheck && npm test && npm run build",
    "check:ci": "npm run format:check && npm run lint && npm run typecheck && npm run test:ci && npm run build && npm run check:docs",
    "smoke:host": "tsx src/smoke/hostPreflight.ts",
    "smoke:discord": "tsx src/smoke/discordConnectivity.ts",
    "smoke:agent": "tsx src/smoke/agentRoundTrip.ts",
    "smoke": "npm run smoke:host && npm run smoke:discord",
    "docs:links": "node scripts/check-docs-links.mjs",
    "check:docs": "npm run docs:links"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^1.2.1",
    "@anthropic-ai/claude-agent-sdk": "^0.2.87",
    "better-sqlite3": "^12.4.1",
    "discord.js": "^14.24.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.10",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.10"
  },
  "keywords": [
    "discord",
    "coding-agent",
    "claude",
    "codex",
    "opencode",
    "ai",
    "git-worktree",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/laurajoyhutchins/discordagent.git"
  },
  "bugs": {
    "url": "https://github.com/laurajoyhutchins/discordagent/issues"
  },
  "engines": {
    "node": ">=22"
  }
}
