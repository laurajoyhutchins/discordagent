{
  "name": "discord-agent",
  "version": "1.0.0",
  "description": "Provider-neutral Discord workspace for durable, isolated coding-agent tasks",
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "register": "tsx src/commands/register.ts",
    "discord:permissions": "tsx src/discord/capabilities/calculator.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check": "npm test && npm run build",
    "smoke:host": "tsx src/smoke/hostPreflight.ts",
    "smoke:discord": "tsx src/smoke/discordConnectivity.ts",
    "smoke": "npm run smoke:host && npm run smoke:discord"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.87",
    "better-sqlite3": "^12.4.1",
    "discord.js": "^14.16.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.10",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=22"
  }
}
