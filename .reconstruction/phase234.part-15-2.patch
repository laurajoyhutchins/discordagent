+import { mkdtempSync,rmSync } from 'node:fs';import{tmpdir}from'node:os';import{join}from'node:path';import{afterEach,describe,expect,it}from'vitest';import{openDatabase}from'../db/database.js';import{runMigrations}from'../db/migrations.js';import{createUsageRepository}from'../repositories/usageRepository.js';import{createProjectRepository}from'../repositories/projectRepository.js';import{createTaskRepository}from'../repositories/taskRepository.js';import{createUsageAdmissionService,UsageAdmissionError}from'./usageAdmission.js';const ps:string[]=[];afterEach(()=>ps.splice(0).forEach(p=>rmSync(p,{recursive:true,force:true})));function setup(){const p=mkdtempSync(join(tmpdir(),'usage-'));ps.push(p);const db=openDatabase(join(p,'db'));runMigrations(db);const repo=createUsageRepository(db);return{db,repo,service:createUsageAdmissionService(repo)};}
+describe('usage admission',()=>{it('creates a pre-task hold and preserves task linkage after completion',async()=>{const{db,repo,service}=setup();const h=await service.reserve({provider:'codex',prompt:'implement a feature'});expect(repo.activeReservations('codex')[0].id).toBe(h.id);db.close();});it('allows repeated reservations to attach to later turns of the same task',async()=>{const{db,repo,service}=setup();const projects=createProjectRepository(db),tasks=createTaskRepository(db);projects.create({name:'p',workingDirectory:'/tmp/p',categoryId:'c',agentChannelId:'a',defaultProvider:'claude'});tasks.createWithWorktree({taskId:'task',projectName:'p',provider:'claude',channelId:'a',threadId:'t',objective:'x',worktree:{id:'w',repositoryPath:'/tmp/p',worktreePath:'/tmp/w',branchName:'agent/claude/x',baseRef:'main'}});const first=await service.reserve({provider:'claude',prompt:'fix a bug'});service.attach(first.id,'task');service.release(first.id);const second=await service.reserve({provider:'claude',prompt:'continue the fix'});expect(()=>service.attach(second.id,'task')).not.toThrow();db.close();});it('rejects work before side effects when safe capacity is insufficient',async()=>{const{db,repo,service}=setup();repo.recordSnapshot({provider:'codex',windowType:'primary',remaining:12,capturedAt:Date.now()});await expect(service.reserve({provider:'codex',prompt:'repository-wide refactor'})).rejects.toBeInstanceOf(UsageAdmissionError);db.close();});});
