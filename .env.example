# Required
DISCORD_TOKEN=your-bot-token-here
DISCORD_CLIENT_ID=your-application-id-here
DISCORD_GUILD_ID=your-server-id-here
AUTHORIZED_ROLE_IDS=role-id-1,role-id-2

# Optional — ping this user when sessions complete
NOTIFY_USER_ID=your-discord-user-id

# Optional — defaults shown

# Optional — exact human owner allowed to manage Codex authentication and use #agent-chat
# Defaults to NOTIFY_USER_ID when omitted
AUTHORIZED_USER_ID=

# Optional — Codex App Server integration
CODEX_ENABLED=true
CODEX_CLI_PATH=codex
CODEX_MODEL=

# Optional — OpenCode ACP integration
OPENCODE_ENABLED=true
OPENCODE_CLI_PATH=opencode
OPENCODE_TIMEOUT_MS=900000
OPENCODE_MODEL=
# Optional — OpenCode-specific model for the restricted PM chat
OPENCODE_PRIMARY_MODEL=

# Optional - keep Claude available as a selectable provider (set false for a Codex-only host)
CLAUDE_ENABLED=true

# Optional — primary PM-style agent model; otherwise each provider uses its own default
PRIMARY_AGENT_MODEL=

# Percentage points reserved for primary-agent coordination when admitting new tasks
PRIMARY_USAGE_RESERVE=10

CLAUDE_TIMEOUT_MS=900000
ROBOREV_CLI_PATH=roborev

# Optional — restrict project paths to a base directory (recommended for security)
# If set, /add-project will only allow paths under this directory
PROJECTS_BASE_DIR=/home/user/projects

# Optional — legacy non-Git registration switch (default: false)
# Agent task execution still requires a Git repository for isolated worktrees.
ALLOW_NON_GIT=false

# Optional — channel ID where usage stats are posted after each session
# Create a #usage channel in your server and paste its ID here
USAGE_CHANNEL_ID=

# Optional — default Claude model for all projects (alias like sonnet/opus/haiku
# or an exact model ID). Per-project overrides via /model take precedence.
CLAUDE_MODEL=

# Optional — SQLite operational store path
# Defaults to data/discordagent.sqlite at the repository root in both dev and compiled runs.
# A sole historical src/data or dist/data installation is reused in place; set this explicitly
# when more than one historical/default data directory contains state.
DATABASE_PATH=

# Optional — directory containing isolated Git task worktrees
# Defaults to a discordagent-worktrees directory beside DATABASE_PATH
WORKTREES_BASE_DIR=

# Optional — localhost port used as a single-instance lock (default: 47831)
# A second bot process exits immediately instead of double-handling messages
INSTANCE_LOCK_PORT=47831

# Optional — interactive terminal REPL for the primary PM agent
# true (default when TTY available): start REPL in interactive terminals
# false: never start the REPL (piped, CI, service-manager environments)
# unset: same as true
TERMINAL_REPL_ENABLED=true
